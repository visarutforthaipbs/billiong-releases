---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Billiong - ออกเอกสารบัญชี สะดวก แม่นยำ จัดการภาษีไทยครบวงจร",
	description = "แอปพลิเคชันออกเอกสารและใบกำกับภาษีสำหรับฟรีแลนซ์และธุรกิจขนาดย่อม คำนวณ VAT และ หัก ณ ที่จ่าย แม่นยำ ปลอดภัยด้วย Local-First Architecture"
} = Astro.props;

// Construct Schema.org JSON-LD for AI search engines (AIEO) & Google
const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Billiong",
  "operatingSystem": "macOS",
  "applicationCategory": "BusinessApplication, FinanceApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "59.00",
    "priceCurrency": "THB",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock"
  }
};
---

<!doctype html>
<html lang="th">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/billiong-logo.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="ออกใบเสร็จ, ใบแจ้งหนี้, ใบกำกับภาษี, คำนวณหัก ณ ที่จ่าย, 50 ทวิ, ฟรีแลนซ์, โปรแกรมบัญชี, macOS, Local-First, พร้อมเพย์ QR, PromptPay QR, บัญชีภาษีฟรีแลนซ์" />
		<meta name="robots" content="index, follow" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/billiong-logo.png" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/billiong-logo.png" />
		
		<!-- AIEO (AI Engine Optimization) JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

		<!-- Google Fonts preconnect & link -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="font-sans antialiased bg-[#f2efe9] text-[#26221a] selection:bg-[#1f5d43]/20 selection:text-[#1f5d43]">
		<slot />
	</body>
</html>
