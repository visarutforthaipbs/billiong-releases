---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import AppDemo from '../components/AppDemo.astro';
import Features from '../components/Features.astro';
import Security from '../components/Security.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import { Download, Info } from '@lucide/astro';
---

<Layout title="Billiong - ออกเอกสารบัญชี สะดวก แม่นยำ จัดการภาษีไทยครบจบในที่เดียว">
	<Navbar />
	<main>
		<Hero />
		<AppDemo />
		<Features />
		<Security />
		<Faq />
	</main>
	<Footer />

	<!-- macOS-Style Trust-Based Purchase & Download Dialog (Centered, No Emojis) -->
	<dialog id="download-dialog" class="fixed inset-0 m-auto backdrop:bg-slate-900/60 backdrop:backdrop-blur-xs bg-white rounded-2xl p-6 mac-window-shadow border border-border-custom w-[calc(100%-2rem)] max-w-md focus:outline-none overflow-hidden">
		<div class="space-y-5">
			<div class="flex items-center justify-between">
				<h3 class="text-base md:text-lg font-bold text-slate-900 flex items-center gap-2">
					<Download class="text-primary shrink-0" size={18} />
					<span>ซื้อลิขสิทธิ์ Billiong (Early Bird)</span>
				</h3>
				<button id="close-dialog-btn" class="w-6 h-6 rounded-full flex items-center justify-center text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer text-sm font-semibold">✕</button>
			</div>
			
			<div class="space-y-4 text-center">
				<div class="text-slate-500 text-xs md:text-sm leading-relaxed">
					สนับสนุนนักพัฒนาช่วงเริ่มต้นในราคาพิเศษเพียง
					<div class="text-3xl font-extrabold text-[#1f5d43] font-display mt-1">฿59.00</div>
					<div class="text-[11px] text-slate-400 mt-0.5">(จ่ายครั้งเดียวใช้งานได้ตลอดชีพ)</div>
				</div>

				<!-- PromptPay QR Code (Using dynamic free promptpay.io API) -->
				<div class="bg-[#f6f4f0] border border-border-custom rounded-xl p-4">
					<img 
						src="https://promptpay.io/0627283058/59.png" 
						alt="PromptPay QR Code 59 THB" 
						class="w-44 h-44 mx-auto border border-slate-200 rounded-lg p-1.5 bg-white shadow-xs" 
					/>
					<div class="text-[11px] text-slate-500 font-medium mt-2 flex items-center justify-center gap-1.5">
						<span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
						สแกนจ่ายผ่านแอปพลิเคชันธนาคาร
					</div>
				</div>
			</div>

			<div class="space-y-2 pt-2">
				<a 
					href="https://pub-4ed16d146bff4f168839661507e1748a.r2.dev/billiong-app-v1.0.dmg" 
					download 
					id="download-confirm-btn" 
					class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-semibold text-white bg-[#1f5d43] hover:bg-[#1a503a] rounded-xl shadow-md transition-all active:scale-98 cursor-pointer text-center"
				>
					<Download size={15} />
					ฉันชำระเงินแล้ว • ดาวน์โหลดแอป (.dmg)
				</a>
				<button 
					id="dialog-cancel-btn" 
					class="w-full py-2.5 text-xs font-semibold text-slate-500 hover:text-slate-700 hover:bg-slate-50 border border-slate-200 transition-colors cursor-pointer rounded-xl"
				>
					ยกเลิก
				</button>
			</div>
		</div>
	</dialog>
</Layout>

<script>
	const downloadDialog = document.getElementById('download-dialog') as HTMLDialogElement;
	const closeDialogBtn = document.getElementById('close-dialog-btn');
	const dialogCancelBtn = document.getElementById('dialog-cancel-btn');
	const downloadConfirmBtn = document.getElementById('download-confirm-btn');

	document.querySelectorAll('a[href="#download"]').forEach(link => {
		link.addEventListener('click', (e) => {
			e.preventDefault();
			downloadDialog?.showModal();
		});
	});

	function closeDialog() {
		downloadDialog?.close();
	}

	closeDialogBtn?.addEventListener('click', closeDialog);
	dialogCancelBtn?.addEventListener('click', closeDialog);

	downloadConfirmBtn?.addEventListener('click', () => {
		// Auto close dialog after a small delay to start download smoothly
		setTimeout(() => {
			closeDialog();
		}, 800);
	});

	downloadDialog?.addEventListener('click', (e) => {
		if (e.target === downloadDialog) {
			closeDialog();
		}
	});
</script>
