---
import { ChevronDown, HelpCircle } from '@lucide/astro';

const title = "คำถามที่พบบ่อย (FAQ)";
const questions = [
  {
    q: "แอปนี้ต้องจ่ายค่าบริการรายเดือนไหม?",
    a: "ไม่ต้องจ่ายรายเดือนครับ Billiong เป็นแอปพลิเคชันแบบ Local-first ที่รันบนเครื่องของคุณ ข้อมูลถูกเก็บไว้ในไฟล์บนคอมพิวเตอร์ของคุณเอง ไม่มีค่าบริการแอบแฝง"
  },
  {
    q: "ข้อมูลจะหายไหมถ้าคอมพิวเตอร์พัง?",
    a: "แอปมีระบบ Auto rolling snapshot ทุกๆ 30 นาที (เก็บย้อนหลัง 14 เวอร์ชัน) อย่างไรก็ตาม แนะนำให้บันทึกหรือลิงก์ไฟล์ billing.json ไว้ในโฟลเดอร์ Google Drive หรือ Dropbox ของเครื่องเพื่อความปลอดภัยสูงสุด"
  },
  {
    q: "ระบบ PromptPay QR ปลอดภัยไหม?",
    a: "ปลอดภัย 100% ครับ เพราะ Billiong ใช้ตัวเข้ารหัส EMVCo payload ที่เขียนขึ้นเองจากศูนย์ แปลงเป็น SVG QR Code ภายในตัวแอป โดยไม่มีการต่อสายนอกหรือส่งข้อมูลเลขบัญชี/เบอร์โทรของคุณไปยังเซิร์ฟเวอร์ใดๆ ทั้งสิ้น"
  }
];
---

<section id="faq" class="py-20 md:py-28 bg-white border-t border-border-custom">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="inline-flex items-center justify-center p-2.5 rounded-full bg-primary/10 text-primary mb-4">
        <HelpCircle size={24} />
      </div>
      <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">
        {title}
      </h2>
      <p class="text-slate-500 text-sm md:text-base mt-2">
        ตอบทุกข้อสงสัยเกี่ยวกับระบบบัญชี Local-First และการจัดการความปลอดภัย
      </p>
    </div>

    <!-- Accordion Details list -->
    <div class="space-y-4">
      {questions.map((item) => (
        <details class="group border border-border-custom rounded-xl overflow-hidden bg-slate-50/10 open:bg-white open:shadow-2xs transition-all duration-200">
          <summary class="flex items-center justify-between p-5 text-sm md:text-base font-bold text-slate-800 cursor-pointer list-none select-none focus:outline-none hover:text-primary hover:bg-slate-50/30">
            <span>{item.q}</span>
            <span class="chevron-wrapper text-slate-400 group-hover:text-primary transition-transform duration-300">
              <ChevronDown size={18} />
            </span>
          </summary>
          <div class="p-5 pt-0 text-sm md:text-base text-slate-500 border-t border-border-custom/50 leading-relaxed bg-white">
            {item.a}
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
  summary {
    display: flex;
  }

  details[open] .chevron-wrapper {
    transform: rotate(180deg);
    color: #1f513b;
  }
</style>
