---
import { Laptop, MousePointerClick, ShieldCheck } from '@lucide/astro';
---

<section id="web-app" class="py-16 md:py-24 bg-[#ece7dc] border-y border-border-custom">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Title Section -->
    <div class="text-center max-w-3xl mx-auto mb-10">
      <div class="inline-flex items-center justify-center p-3 rounded-full bg-[#1f5d43]/15 text-[#1f5d43] mb-4">
        <Laptop size={32} />
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">
        ลองใช้ Billiong ตัวจริง ได้เลยที่นี่
      </h2>
      <p class="text-slate-500 text-base md:text-lg font-medium">
        นี่คือแอปตัวจริง ไม่ใช่ภาพจำลอง — กดสร้างเอกสาร คำนวณ VAT และหัก ณ ที่จ่าย ได้เหมือนตอนติดตั้งจริงทุกอย่าง
      </p>
    </div>

    <!-- Interaction hints -->
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-6 text-xs md:text-[13px] font-medium text-slate-500">
      <span class="inline-flex items-center gap-1.5">
        <MousePointerClick size={14} class="text-primary" />
        คลิกเมนูด้านซ้ายเพื่อสำรวจทุกฟังก์ชัน
      </span>
      <span class="inline-flex items-center gap-1.5">
        <ShieldCheck size={14} class="text-primary" />
        ข้อมูลตัวอย่างเก็บไว้ในเบราว์เซอร์ของคุณเท่านั้น (Local-First)
      </span>
    </div>

    <!-- macOS Window Container (hosts the real app in an iframe) -->
    <div class="billiong-app-sim w-full max-w-7xl mx-auto rounded-2xl border border-[#dcd5c5] bg-[#ece7dc] mac-window-shadow overflow-hidden animate-float-window">

      <!-- macOS Titlebar -->
      <div class="titlebar flex items-center justify-between px-4 py-2.5 bg-[#f4f1e8] border-b border-[#dcd5c5]">
        <!-- Traffic lights -->
        <div class="flex items-center gap-1.5 w-24">
          <div class="w-3 h-3 rounded-full bg-[#ff5f56] border border-[#e0443e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#ffbd2e] border border-[#df9e13]"></div>
          <div class="w-3 h-3 rounded-full bg-[#27c93f] border border-[#1aab29]"></div>
        </div>
        <!-- Title -->
        <div class="text-[11px] font-bold text-[#5f594c] flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1f7a4d] animate-pulse"></span>
          Billiong — billing.json
        </div>
        <!-- Buffer -->
        <div class="w-24"></div>
      </div>

      <!-- The actual Billiong app, seeded with sample data -->
      <iframe
        src="/demo-app.html"
        title="Billiong Interactive Demo"
        loading="lazy"
        class="w-full block bg-[#ece7dc] h-[620px] md:h-[720px]"
      ></iframe>
    </div>

  </div>
</section>
